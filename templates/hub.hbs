<div class="rnk-mystix-hub-wrapper">
    <div class="rnk-mystix-header">
        <h2>RNK™ Mystix</h2>
        <p>{{i18n.pointSystem}}</p>
    </div>

    <div class="rnk-mystix-controls">
        <div class="rnk-mystix-search-box">
            <input type="text" class="rnk-mystix-search" placeholder="{{i18n.searchPlaceholder}}" value="{{searchQuery}}">
        </div>
        <button class="rnk-mystix-reset-all-btn" title="{{i18n.resetAllTitle}}">
            <i class="fas fa-redo"></i> {{i18n.resetAllLabel}}
        </button>
    </div>

    <div class="rnk-mystix-content">
        {{#if isSearching}}
            <!-- Search results -->
            <div class="rnk-mystix-actors-list">
                {{#if actors.length}}
                    {{#each actors as |actor| ~}}
                        <div class="rnk-mystix-actor-row" data-actor-id="{{actor.id}}">
                            <div class="rnk-mystix-actor-info">
                                <div class="rnk-mystix-actor-name">{{actor.name}}</div>
                                <div class="rnk-mystix-actor-type">{{actor.type}}</div>
                            </div>

                            <div class="rnk-mystix-point-inputs">
                                <div class="rnk-mystix-point-group hero">
                                    <label>{{i18n.heroPoints}}</label>
                                    <input type="number" class="rnk-mystix-hero-input" value="{{actor.heroPoints}}">
                                </div>
                                <div class="rnk-mystix-point-group mystic">
                                    <label>{{i18n.mysticPoints}}</label>
                                    <input type="number" class="rnk-mystix-mystic-input" value="{{actor.mysticPoints}}">
                                </div>
                            </div>

                            <div class="rnk-mystix-actions">
                                <button class="rnk-mystix-assign-btn" title="{{i18n.assignTitle}}">{{i18n.assign}}</button>
                                <button class="rnk-mystix-clear-btn" title="{{i18n.clearTitle}}">{{i18n.clear}}</button>
                                <button class="rnk-mystix-reset-btn" title="{{i18n.resetTitle}}">{{i18n.reset}}</button>
                            </div>
                        </div>
                    {{~/each}}
                {{else}}
                    <div class="rnk-mystix-no-results">{{i18n.noSearchResults}}</div>
                {{/if}}
            </div>
        {{else}}
            <!-- Grouped view -->
            <div class="rnk-mystix-actors-grouped">
                {{#if pcs.length}}
                    <div class="rnk-mystix-group">
                        <h3 class="rnk-mystix-group-header">{{i18n.pcs}}</h3>
                        {{#each pcs as |actor| ~}}
                            <div class="rnk-mystix-actor-row" data-actor-id="{{actor.id}}">
                                <div class="rnk-mystix-actor-info">
                                    <div class="rnk-mystix-actor-name">{{actor.name}}</div>
                                </div>

                                <div class="rnk-mystix-point-inputs">
                                    <div class="rnk-mystix-point-group hero">
                                        <label>{{i18n.heroPoints}}</label>
                                        <input type="number" class="rnk-mystix-hero-input" value="{{actor.heroPoints}}">
                                    </div>
                                    <div class="rnk-mystix-point-group mystic">
                                        <label>{{i18n.mysticPoints}}</label>
                                        <input type="number" class="rnk-mystix-mystic-input" value="{{actor.mysticPoints}}">
                                    </div>
                                </div>

                                <div class="rnk-mystix-actions">
                                    <button class="rnk-mystix-assign-btn" title="{{i18n.assignTitle}}">{{i18n.assign}}</button>
                                    <button class="rnk-mystix-clear-btn" title="{{i18n.clearTitle}}">{{i18n.clear}}</button>
                                    <button class="rnk-mystix-reset-btn" title="{{i18n.resetTitle}}">{{i18n.reset}}</button>
                                </div>
                            </div>
                        {{~/each}}
                    </div>
                {{/if}}

                {{#if npcs.length}}
                    <div class="rnk-mystix-group">
                        <h3 class="rnk-mystix-group-header">{{i18n.npcs}}</h3>
                        {{#each npcs as |actor| ~}}
                            <div class="rnk-mystix-actor-row" data-actor-id="{{actor.id}}">
                                <div class="rnk-mystix-actor-info">
                                    <div class="rnk-mystix-actor-name">{{actor.name}}</div>
                                </div>

                                <div class="rnk-mystix-point-inputs">
                                    <div class="rnk-mystix-point-group hero">
                                        <label>{{i18n.heroPoints}}</label>
                                        <input type="number" class="rnk-mystix-hero-input" value="{{actor.heroPoints}}">
                                    </div>
                                    <div class="rnk-mystix-point-group mystic">
                                        <label>{{i18n.mysticPoints}}</label>
                                        <input type="number" class="rnk-mystix-mystic-input" value="{{actor.mysticPoints}}">
                                    </div>
                                </div>

                                <div class="rnk-mystix-actions">
                                    <button class="rnk-mystix-assign-btn" title="{{i18n.assignTitle}}">{{i18n.assign}}</button>
                                    <button class="rnk-mystix-clear-btn" title="{{i18n.clearTitle}}">{{i18n.clear}}</button>
                                    <button class="rnk-mystix-reset-btn" title="{{i18n.resetTitle}}">{{i18n.reset}}</button>
                                </div>
                            </div>
                        {{~/each}}
                    </div>
                {{/if}}

                {{#if mystics.length}}
                    <div class="rnk-mystix-group">
                        <h3 class="rnk-mystix-group-header">{{i18n.others}}</h3>
                        {{#each mystics as |actor| ~}}
                            <div class="rnk-mystix-actor-row" data-actor-id="{{actor.id}}">
                                <div class="rnk-mystix-actor-info">
                                    <div class="rnk-mystix-actor-name">{{actor.name}}</div>
                                </div>

                                <div class="rnk-mystix-point-inputs">
                                    <div class="rnk-mystix-point-group hero">
                                        <label>{{i18n.heroPoints}}</label>
                                        <input type="number" class="rnk-mystix-hero-input" value="{{actor.heroPoints}}">
                                    </div>
                                    <div class="rnk-mystix-point-group mystic">
                                        <label>{{i18n.mysticPoints}}</label>
                                        <input type="number" class="rnk-mystix-mystic-input" value="{{actor.mysticPoints}}">
                                    </div>
                                </div>

                                <div class="rnk-mystix-actions">
                                    <button class="rnk-mystix-assign-btn" title="{{i18n.assignTitle}}">{{i18n.assign}}</button>
                                    <button class="rnk-mystix-clear-btn" title="{{i18n.clearTitle}}">{{i18n.clear}}</button>
                                    <button class="rnk-mystix-reset-btn" title="{{i18n.resetTitle}}">{{i18n.reset}}</button>
                                </div>
                            </div>
                        {{~/each}}
                    </div>
                {{/if}}

                {{#unless hasActors}}
                    <div class="rnk-mystix-no-results">{{i18n.noActors}}</div>
                {{~/unless}}
            </div>
        {{/if}}
    </div>
</div>
